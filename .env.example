REDIS_PORT=6379
REDIS_PASSWORD=Welabs123456Secure!
REDIS_SSL=true

# --- RabbitMQ (EKS in-cluster) ---
RABBITMQ_HOST=rabbitmq.forenshield.svc.cluster.local
RABBITMQ_PORT=5672
RABBITMQ_USER=forenshield
RABBITMQ_PASSWORD=Welabs2026!

