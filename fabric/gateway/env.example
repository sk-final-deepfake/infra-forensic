# Fabric Anchor Gateway — 환경 변수 (PoC)
# cp env.example .env 후 경로 수정

GATEWAY_PORT=8088
GATEWAY_API_KEY=

FABRIC_NETWORK_LABEL=hyperledger-fabric-forenshield
FABRIC_CHANNEL=forenshield-evidence
FABRIC_CHAINCODE=anchor
FABRIC_MSP_ID=Org1MSP

# test-network 기본 peer (동일 호스트에서 Gateway 실행 시)
FABRIC_PEER_ENDPOINT=localhost:7051
FABRIC_PEER_HOST_ALIAS=peer0.org1.example.com

# scripts/write-gateway-env.sh 가 채워 줌
FABRIC_TLS_CERT_PATH=
FABRIC_CERT_PATH=
FABRIC_KEY_PATH=
