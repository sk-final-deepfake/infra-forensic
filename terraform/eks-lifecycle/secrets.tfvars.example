# cp secrets.tfvars.example secrets.tfvars
# config/secrets.env 값을 복사 (Git 커밋 금지)

postgres_password = "CHANGE_ME"
redis_password    = "CHANGE_ME"
rabbitmq_password = "CHANGE_ME"
jwt_secret_key    = "CHANGE_ME"
argocd_admin_password = "CHANGE_ME"

# Manifest X.509 서명 (PKCS#8 + cert). park/wake 시 app-secrets 로 자동 재생성.
# 팀원이 쓰던 PEM 전체를 그대로 넣으면 됨 (줄바꿈 포함 heredoc).
# 비워 두면 JWT만 들어가고, backend 는 서명 키 없어 CrashLoop 날 수 있음.
manifest_signing_private_key_pem = <<-EOT
-----BEGIN PRIVATE KEY-----
CHANGE_ME
-----END PRIVATE KEY-----
EOT

manifest_signing_certificate_pem = <<-EOT
-----BEGIN CERTIFICATE-----
CHANGE_ME
-----END CERTIFICATE-----
EOT
